{
  "name": "aibrd",
  "displayName": "AIBRD — BRD Layer + Judgment Layer",
  "description": "Convert BRDs into living specs. Review every PR. Stress-test designs. Resolve deadlocks. All inside Copilot — no extra API keys.",
  "version": "0.2.0",
  "publisher": "anirudhyadav",
  "license": "MIT",
  "engines": { "vscode": "^1.93.0" },
  "categories": ["AI", "Linters", "Other"],
  "keywords": ["aibrd", "copilot", "brd", "code review", "architecture", "ADR", "judge", "advocate", "mediator"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "aibrd.init",             "title": "aibrd: Initialize from BRD",             "category": "aibrd" },
      { "command": "aibrd.update",           "title": "aibrd: Update with new requirement",      "category": "aibrd" },
      { "command": "aibrd.generateTests",    "title": "aibrd: Generate Test Cases",              "category": "aibrd" },
      { "command": "aibrd.releaseNotes",     "title": "aibrd: Generate Release Notes",           "category": "aibrd" },
      { "command": "aibrd.showRtm",          "title": "aibrd: Show Traceability Matrix",         "category": "aibrd" },
      { "command": "aibrd.showGaps",         "title": "aibrd: Show Gap Report",                  "category": "aibrd" },
      { "command": "aibrd.changeImpact",     "title": "aibrd: Analyse Change Impact",            "category": "aibrd" },
      { "command": "aibrd.validateContext",  "title": "aibrd: Validate CONTEXT.md",              "category": "aibrd" },
      { "command": "aibrd.prDraft",          "title": "aibrd: Draft Pull Request Description",   "category": "aibrd" },
      { "command": "aibrd.sprintFeed",       "title": "aibrd: Generate Sprint Feed",             "category": "aibrd" },
      { "command": "aibrd.apiContracts",     "title": "aibrd: Derive API Contracts",             "category": "aibrd" },
      { "command": "aibrd.poReport",         "title": "aibrd: Generate PO Progress Report",      "category": "aibrd" },
      { "command": "aibrd.complianceMapper", "title": "aibrd: Map Compliance Frameworks",        "category": "aibrd" },
      { "command": "aibrd.ingestConfluence", "title": "aibrd: Ingest from Confluence",           "category": "aibrd" },
      { "command": "aibrd.staleDetector",    "title": "aibrd: Check Requirement Staleness",      "category": "aibrd" },
      { "command": "aibrd.testLinkage",      "title": "aibrd: Link Requirements to Test Files",  "category": "aibrd" }
    ],
    "chatParticipants": [
      {
        "id": "aibrd.assistant",
        "name": "aibrd",
        "description": "Query your BRD — flows, rules, tasks, coverage, RTM",
        "isSticky": false
      },
      {
        "id": "aibrd.judge",
        "name": "judge",
        "fullName": "AIBRD Judge",
        "description": "Review code against your team's rubric. Returns APPROVE / REQUEST_CHANGES / BLOCK with severity-graded findings.",
        "isSticky": false,
        "commands": [
          { "name": "review",   "description": "Review the active file or selection against the team rubric" },
          { "name": "security", "description": "Run a security audit (OWASP Top-10 focus)" }
        ]
      },
      {
        "id": "aibrd.advocate",
        "name": "advocate",
        "fullName": "AIBRD Advocate",
        "description": "Stress-test proposals before committing. Generate Architecture Decision Records.",
        "isSticky": false,
        "commands": [
          { "name": "adr",   "description": "Generate an Architecture Decision Record from a proposal" },
          { "name": "devil", "description": "Devil's Advocate — stress-test a proposal before agent handoff" }
        ]
      },
      {
        "id": "aibrd.mediator",
        "name": "mediator",
        "fullName": "AIBRD Mediator",
        "description": "Resolve sprint-blocking engineering disagreements. Finds synthesis, not a winner.",
        "isSticky": false,
        "commands": [
          { "name": "design", "description": "Mediate a design conflict between two engineering positions" },
          { "name": "deps",   "description": "Resolve a dependency version conflict" }
        ]
      }
    ],
    "views": {
      "explorer": [
        { "id": "aibrd.rtmView", "name": "aibrd Traceability" }
      ]
    },
    "configuration": {
      "title": "aibrd",
      "properties": {
        "aibrd.preferredModel": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Copilot model to use for BRD analysis"
        },
        "aibrd.maxChunkTokens": {
          "type": "number",
          "default": 6000,
          "description": "Max tokens per BRD chunk sent to LLM"
        },
        "aibrd.confluenceBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Default Confluence base URL (e.g. https://yourorg.atlassian.net)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "jest",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"]
  },
  "dependencies": {
    "mammoth": "^1.7.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "typescript": "^5.4.0",
    "ts-jest": "^29.0.0",
    "jest": "^29.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
